{
  "version": 2,
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "src/server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/app", "dest": "/public/app.html" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/(.*)", "dest": "src/server.ts" }
  ]
}
